# ===========================================
# API Keys (Required / 必填)
# ===========================================

# Twelve Data API (Free 800 calls/day)
# Get: https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_api_key_here

# Alpha Vantage API (Free 25 calls/day)
# Get: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_api_key_here

# ===========================================
# Notification Configuration (Optional / 可选)
# ===========================================
# Leave empty to disable notifications
# 留空则禁用推送通知

# Feishu / 飞书 (Optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# DingTalk / 钉钉 (Optional)
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_CHAT_ID=

# Email / 邮件 (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# ===========================================
# Trading Configuration (Optional / 可选)
# ===========================================

# Risk Profile: conservative / moderate / aggressive
# 风险偏好：保守型 / 稳健型 / 进取型
RISK_PROFILE=moderate

# Default Capital ($)
# 默认总资金 (美元)
DEFAULT_CAPITAL=100000

# Watchlist File (Optional)
# 自选股列表文件路径 (可选，留空使用默认列表)
WATCHLIST_FILE=

# ===========================================
# Language (Optional / 可选)
# ===========================================
# Default: en (English)
# Options: en, zh_CN
# 默认：en (英文)
# 选项：en, zh_CN (中文)
TRADING_ASSISTANT_LANG=en
