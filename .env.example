# Twelve Data API (Free 800 calls/day)
# Get: https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_api_key_here

# Alpha Vantage API (Free 25 calls/day)
# Get: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_api_key_here

# Feishu Push Configuration (Optional)
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=your_chat_id

# Risk Profile (conservative/moderate/aggressive)
RISK_PROFILE=moderate

# Default Capital ($)
DEFAULT_CAPITAL=100000

# Language (en or zh_CN)
# Default: en (English)
# Options: en, zh_CN
TRADING_ASSISTANT_LANG=en
